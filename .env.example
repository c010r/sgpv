DJANGO_ENV=development
DEBUG=1
SECRET_KEY=changeme-dev-secret
ALLOWED_HOSTS=*
TZ=America/Montevideo

# PostgreSQL (produccion)
DB_NAME=sgpv
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis/Celery (escalabilidad)
USE_REDIS=0
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=0
ENABLE_PERIODIC_TASKS=1

# Alertas (webhook/email) + umbrales
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SIGNING_SECRET=
ALERT_WEBHOOK_SIGNATURE_HEADER=X-SGPV-Signature
ALERT_WEBHOOK_TIMESTAMP_HEADER=X-SGPV-Timestamp
ALERT_EMAIL_TO=
ALERT_SLACK_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_MAX_RETRIES=3
ALERT_LOW_STOCK_THRESHOLD=10
ALERT_CASH_DIFF_THRESHOLD=0
ALERT_DEDUP_WINDOW_MINUTES=30

# Seguridad/infra
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
THROTTLE_USER_RATE=3000/hour
THROTTLE_ANON_RATE=100/hour
THROTTLE_SALES_CREATE_RATE=120/minute
THROTTLE_REPORTS_READ_RATE=600/minute
THROTTLE_REPORTS_WRITE_RATE=120/minute
THROTTLE_ALERTS_SCAN_RATE=30/minute
LOG_LEVEL=INFO
