[Unit]
Description=SGPV Celery Worker
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/sgpv
EnvironmentFile=/opt/sgpv/.env
ExecStart=/opt/sgpv/.venv/bin/celery -A config worker --loglevel=info --concurrency=4
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
